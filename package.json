{
  "name": "appvault",
  "version": "0.2.1",
  "description": "Utility for structured application launching",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "dist": "electron-builder --win --x64"
  },
  "author": "k3fya",
  "license": "MIT",
  "devDependencies": {
    "cross-env": "^10.0.0",
    "electron": "^26.0.0",
    "electron-builder": "^26.7.0",
    "electron-reload": "^2.0.0-alpha.1"
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "semver": "^7.7.2"
  },
  "build": {
    "appId": "com.k3fya.appvault",
    "productName": "AppVault",
    "directories": {
      "output": "dist",
      "buildResources": "src/assets"
    },
    "files": [
      "src/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "src/config/",
        "to": "config/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "src/assets/avlogo.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": null
  }
}